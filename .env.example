# Google Sheets — append booking leads from POST /api/lead
# 1. Create a Google Cloud project → enable Google Sheets API
# 2. Create a service account → JSON key → copy client_email + private_key here
# 3. Create a Sheet → paste row 1 from client-scope/GOOGLE-SHEET-HEADERS.csv (exact headers)
# 4. Share the Sheet with the service account email (Editor)

GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB_NAME=Leads
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Google Analytics 4 — get from analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
